print("P2_SMOKE_BEGIN bytes")

def expect_error(f, error_type)
    var caught = false
    try
        f()
    except .. as e, m
        caught = true
        assert(e == error_type)
    end
    assert(caught)
end

var api = bytes()
assert(type(api.size) == "function")
assert(type(api.add) == "function")
assert(type(api.get) == "function")
assert(type(api.resize) == "function")
assert(type(api.clear) == "function")
assert(type(api.append) == "function")
assert(type(api.appendhex) == "function")
assert(type(api.copy) == "function")
assert(type(api.asstring) == "function")
assert(type(api.fromstring) == "function")
assert(type(api.tohex) == "function")

assert(str(bytes()) == "bytes('')")
assert(str(bytes("")) == "bytes('')")
assert(str(bytes(0)) == "bytes('')")
assert(str(bytes(1)) == "bytes('')")
assert(str(bytes(-1)) == "bytes('00')")
assert(str(bytes("1122AAaaBBbb")) == "bytes('1122AAAABBBB')")
assert(bytes("1122AAaaBBbb").size() == 6)
assert(str(bytes("112")) == "bytes('11')")
assert(str(bytes("++")) == "bytes('00')")

var b = bytes()
b.add(0x22)
assert(str(b) == "bytes('22')")
b.add(0x12345678, 0)
assert(str(b) == "bytes('22')")
b.add(0x12345678, 1)
assert(str(b) == "bytes('2278')")
b.add(0x12345678, 2)
assert(str(b) == "bytes('22787856')")
b.add(0x12345678, -2)
assert(str(b) == "bytes('227878565678')")

b = bytes("000102030405")
assert(b.get(0) == 0)
assert(b.get(-1) == 0x05)
assert(b.get(6) == 0)
assert(b.get(-1000) == 0)
assert(b.get(1000) == 0)
assert(b.get(1, 1) == 0x01)
assert(b.get(1, 2) == 0x0201)
assert(b.get(1, 4) == 0x04030201)
assert(b.get(1, -2) == 0x0102)
assert(b.get(1, -4) == 0x01020304)
assert(b.get(1, 0) == 0)

b = bytes("112233")
b.resize(2)
assert(str(b) == "bytes('1122')")
assert(b.size() == 2)
b.resize(4)
assert(str(b) == "bytes('11220000')")
assert(b.size() == 4)
b.resize(0)
assert(str(b) == "bytes('')")
assert(b.size() == 0)
b = bytes("112233")
b.resize(-5)
assert(str(b) == "bytes('')")

b = bytes("aabb")
b.clear()
assert(str(b) == "bytes('')")

assert(bytes() == bytes())
assert(bytes("11") == bytes("11"))
assert(bytes("11") == bytes()..0x11)
assert(bytes("11") != bytes("1122"))
assert(bytes("11") != bytes("12"))
assert(bytes("11") != bytes())

var b1 = bytes("1122")
var b2 = bytes("334455")
var b3 = b1 + b2
assert(str(b1) == "bytes('1122')")
assert(str(b2) == "bytes('334455')")
assert(str(b3) == "bytes('1122334455')")
assert(str(bytes("AA") + "01") == "bytes('AA3031')")

b1 = bytes("1122")
assert(str(b1.append(bytes("334455"))) == "bytes('1122334455')")
assert(str(b1) == "bytes('1122334455')")
b1 = bytes("AA")
assert(str(b1.append(bytes())) == "bytes('AA')")
assert(str(b1) == "bytes('AA')")
b1 = bytes("AA")
b1.append("01")
assert(str(b1) == "bytes('AA3031')")

assert(bytes().appendhex(bytes("DEADBEEF")) == bytes("4445414442454546"))
assert(bytes("AABBCC").appendhex(bytes("")) == bytes("AABBCC"))

b = bytes("334455")
assert(b[0] == 0x33)
assert(b[1] == 0x44)
assert(b[2] == 0x55)
assert(b[-1] == 0x55)
assert(b[-2] == 0x44)
expect_error(def () return b[-4] end, "index_error")
expect_error(def () return b[4] end, "index_error")

b = bytes("00112233445566778899AABBCCDDEEFF")
assert(str(b[1..1]) == "bytes('11')")
assert(str(b[-1..1]) == "bytes('')")
assert(str(b[0..40]) == "bytes('00112233445566778899AABBCCDDEEFF')")
assert(str(b[1..0]) == "bytes('')")
assert(b[0..-1] == b)
assert(b[1..-2] == bytes("112233445566778899AABBCCDDEE"))
assert(b[5..10] == bytes("5566778899AA"))
assert(b[-10..-5] == bytes("66778899AABB"))
assert(b[7..-12] == bytes())
var slice_copy = b[1..2]
slice_copy[0] = 0xAA
assert(slice_copy == bytes("AA22"))
assert(b[1..2] == bytes("1122"))

b = bytes("112233")
b[1] = 0xAA
assert(str(b) == "bytes('11AA33')")
b[0] = 0xBB
assert(str(b) == "bytes('BBAA33')")
b[-1] = 0xFE
assert(str(b) == "bytes('BBAAFE')")
expect_error(def () b[-4] = 0x11 end, "index_error")
expect_error(def () b[4] = 0x11 end, "index_error")

b = bytes("112233")
var copy = b.copy()
assert(str(copy) == "bytes('112233')")
copy.clear()
assert(str(b) == "bytes('112233')")
assert(str(copy) == "bytes('')")
copy = b.copy()
b[0] = 0x44
assert(str(b) == "bytes('442233')")
assert(str(copy) == "bytes('112233')")

assert(bytes().asstring() == "")
assert(bytes("334455").asstring() == "3DU")
b = bytes()
b.fromstring("Aa0")
assert(str(b) == "bytes('416130')")
assert(b.tohex() == "416130")

print("P2_SMOKE_PASS bytes")
