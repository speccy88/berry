print("P2_SMOKE_BEGIN bytes_extra")

def expect_type_error(f)
    try
        f()
        assert(false)
    except .. as e, m
        assert(e == "type_error")
    end
end

var api = bytes()
assert(type(api.set) == "function")
assert(type(api.setfloat) == "function")
assert(type(api.getfloat) == "function")
assert(type(api.addfloat) == "function")
assert(type(api.fromhex) == "function")
assert(type(api.setbytes) == "function")
assert(type(api.reverse) == "function")
assert(type(api.tobool) == "function")
assert(type(api.tob64) == "function")
assert(type(api.appendb64) == "function")

var b = bytes("00000000")
b.setfloat(0, 0.33)
assert(b == bytes("C3F5A83E"))

b = bytes("0000C03F")
assert(b.getfloat(0) == 1.5)
b.addfloat(0.33)
assert(b == bytes("0000C03FC3F5A83E"))
b.addfloat(0.33, true)
assert(b == bytes("0000C03FC3F5A83E3EA8F5C3"))

b = bytes("112233")
b.fromhex("FFFEAABBCC")
assert(b == bytes("FFFEAABBCC"))
b.fromhex("")
assert(b == bytes())
assert(bytes("FFFEAABBCC").tohex() == "FFFEAABBCC")
assert(bytes().tohex() == "")

var source = bytes("112233445566778899")
var fill = bytes("AABBCCDDEEFF")
var target = source.copy()
target.setbytes(0, fill)
assert(target == bytes("AABBCCDDEEFF778899"))
assert(fill == bytes("AABBCCDDEEFF"))
target = source.copy()
target.setbytes(0, fill, 0, 0)
assert(target == source)
target = source.copy()
target.setbytes(100, fill)
assert(target == source)
target = source.copy()
target.setbytes(6, fill)
assert(target == bytes("112233445566AABBCC"))
target = source.copy()
target.setbytes(6, fill, 2, 2)
assert(target == bytes("112233445566CCDD99"))

assert(bytes().reverse() == bytes())
assert(bytes("AA").reverse() == bytes("AA"))
assert(bytes("1122334455").reverse() == bytes("5544332211"))
assert(bytes("0011223344").reverse(1, 3) == bytes("0033221144"))
assert(bytes("0011223344").reverse(nil, nil, 2) == bytes("2233001144"))
assert(bytes("001122334455").reverse(nil, nil, 3) == bytes("334455001122"))

assert(bool(bytes()) == false)
assert(bytes().tobool() == false)
assert(!bytes())
assert(bool(bytes("00")) == true)
assert(bytes("00").tobool() == true)
assert(bytes("01").tobool() == true)
assert(bytes("02"))

var original = bytes().fromstring("P2")
var copied = original.copy()
original.set(0, 0x58, 1)
assert(original.asstring() == "X2")
assert(copied.asstring() == "P2")
var shortened_string = bytes("AABBCCDD").fromstring("Hi")
assert(shortened_string == bytes("4869"))
var cleared_string = bytes("AABB").fromstring("")
assert(cleared_string == bytes())

var three = bytes("01020304")
assert(three.get(1, 3) == 0x040302)
assert(three.get(1, -3) == 0x020304)

b = bytes("AABBCC")
var c = bytes("001122")
assert(bytes().fromstring(bytes("001122").tob64()) == bytes("41424569"))
assert(b.appendb64(c) == bytes("AABBCC41424569"))
assert(b.appendb64(bytes()) == bytes("AABBCC41424569"))

b = bytes("AABBCC")
assert(b.appendb64(c, 1) == bytes("AABBCC4553493D"))

b = bytes("1122")
assert(b.add(0x334455, 3) == bytes("1122554433"))
assert(b.add(0x334455, -3) == bytes("1122554433334455"))

var typed = bytes("0000000000")
expect_type_error(def () typed.set(0, 0.5, 4) end)
expect_type_error(def () typed.set(0, nil, 4) end)
expect_type_error(def () typed.set(0, 1, nil) end)
expect_type_error(def () typed.add(0.5, 4) end)
expect_type_error(def () typed.add(nil, 4) end)
expect_type_error(def () typed.add(5, 1.5) end)
expect_type_error(def () typed.addfloat(true) end)
expect_type_error(def () typed.addfloat(nil) end)

print("P2_SMOKE_PASS bytes_extra")
